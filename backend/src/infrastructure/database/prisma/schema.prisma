generator client {
    provider = "prisma-client-js"
    output   = "../generated/prisma"
}

datasource db {
    provider = "postgresql"
}

model Article {
    id         Int                 @id @default(autoincrement())
    title      String
    content    String
    image      String?
    author_id String
    base_views Int                 @default(0)
    created_at DateTime            @default(now())
    updated_at DateTime            @default(now())
    category   CategoryOnArticle[]
    author     User[]
}

model Category {
    id         Int                 @id @default(autoincrement())
    name       String
    article    CategoryOnArticle[]
    created_at DateTime            @default(now())
    updated_at DateTime            @default(now())
}

model User {
    id         String                @id @default(uuid())
    email      String                @unique
    username   String
    password   String?
    authlogs   Session_audit_trail[]
    roles      String
    created_at DateTime              @default(now())
    updated_at DateTime              @default(now())
    comment    Comment[]
    article    Article[]
}

model Comment {
    id         Int      @id @default(autoincrement())
    user_id    String
    user       User     @relation(fields: [user_id], references: [id])
    created_at DateTime @default(now())
    updated_at DateTime @default(now())
}

model Session_audit_trail {
    id              Int      @id @default(autoincrement())
    admin_id        String
    event_type      String
    device_type     String
    ip_address      String
    success         Boolean
    failure_session String?
    admin           User?    @relation(fields: [admin_id], references: [id])
    created_at      DateTime @default(now())
    updated_at      DateTime @default(now())
}

model CategoryOnArticle {
    category_id Int
    article_id  Int
    article     Article?  @relation(fields: [article_id], references: [id])
    category    Category? @relation(fields: [category_id], references: [id])
    created_at  DateTime  @default(now())
    updated_at  DateTime  @default(now())

    @@id([category_id, article_id])
}
