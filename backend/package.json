{
  "name": "redis",
  "scripts": {
    "dev": "redis-server redis.conf & NODE_OPTIONS='--max-old-space-size=556 --expose-gc' & bun run --hot src/index.ts",
    "db:seed:data": "bun run ./src/infrastructure/database/seeder/data-runner.ts",
    "db:seed:e2e": "bun run ./src/infrastructure/database/seeder/e2e-runner.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "clean": "rm -rf node_modules/.cache"
  },
  "dependencies": {
    "@elastic/elasticsearch": "^9.3.4",
    "@hono/node-server": "^1.19.9",
    "@prisma/adapter-pg": "^7.4.0",
    "@prisma/client": "^7.4.1",
    "crypto-js": "^4.2.0",
    "hono": "^4.11.9",
    "ioredis": "^5.9.3",
    "node-schedule": "^2.1.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "pino-roll": "^4.0.0",
    "prisma": "^7.4.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node-schedule": "^2.1.8",
    "dotenv": "^17.3.1"
  }
}